{
  "name": "powershell-org-hugo",
  "version": "1.0.0",
  "description": "PowerShell.org Hugo static site",
  "type": "module",
  "scripts": {
    "dev": "hugo server -D --disableFastRender",
    "build": "hugo --gc --minify",
    "build:css": "node scripts/build-tailwind.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "preview": "hugo server --environment production"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "hugo-extended": "^0.155.1",
    "node-fetch": "^3.3.2",
    "purgecss": "^5.0.0",
    "subset-font": "^2.5.0"
  }
}
